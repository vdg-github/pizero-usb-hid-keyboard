#!/usr/bin/env bash

# Auto-detect device: use serial port for Pi 3 + Teensy, or hidg0 for Pi Zero
if [ -e /dev/serial0 ]; then
  DEV=/dev/serial0
else
  DEV=/dev/hidg0
fi

# Send each key sequentially to avoid simultaneously pressing all keys
for key in "$@"; do
  echo "$key" | /home/pi/pizero-usb-hid-keyboard/hid-gadget-test "$DEV" keyboard
  sleep 0.05
done
