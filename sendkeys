#!/usr/bin/env bash

# Auto-detect device: use serial port for Pi 3 + Teensy, or hidg0 for Pi Zero
if [ -e /dev/serial0 ]; then
  DEV=/dev/serial0
else
  DEV=/dev/hidg0
fi

HID="/home/pi/pizero-usb-hid-keyboard/hid-gadget-test"

# String mode: sendkeys -s "hello world" or echo "text" | sendkeys -s
if [ "$1" = "-s" ] || [ "$1" = "--string" ]; then
  shift
  if [ $# -gt 0 ]; then
    printf '%s' "$*" | "$HID" "$DEV" --string
  else
    "$HID" "$DEV" --string
  fi
  exit $?
fi

# Mouse mode: sendkeys -m "click" | sendkeys -m "move 10 -5" | sendkeys -m "10 -5 --b1"
if [ "$1" = "-m" ] || [ "$1" = "--mouse" ]; then
  shift
  for cmd in "$@"; do
    echo "$cmd" | "$HID" "$DEV" mouse
    sleep 0.05
  done
  exit $?
fi

# Key mode: send each key sequentially to avoid simultaneously pressing all keys
for key in "$@"; do
  echo "$key" | "$HID" "$DEV" keyboard
  sleep 0.05
done
